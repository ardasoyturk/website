{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "website",
  "main": "./dist/_worker.js/index.js",
  "compatibility_date": "2026-03-05",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/*"
    ],
    "not_found_handling": "404-page",
  }
}